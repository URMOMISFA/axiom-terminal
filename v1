function addHolding(event) {
  event.preventDefault();
  const ticker = document.getElementById('new-ticker').value.toUpperCase();
  const shares = parseFloat(document.getElementById('new-shares').value);
  const buyPrice = parseFloat(document.getElementById('new-price').value);
  if(!ticker || !shares || !buyPrice) return;
  holdings.push({ ticker, shares, buyPrice });
  try { localStorage.setItem(PORTFOLIO_KEY, JSON.stringify(holdings)); } catch (e) {}
  document.getElementById('new-ticker').value = '';
  document.getElementById('new-shares').value = '';
  document.getElementById('new-price').value = '';
  renderPortfolio();
  showToast(`Added ${shares} ${ticker} to portfolio`);
}

function removeHolding(index) {
  holdings.splice(index, 1);
  try { localStorage.setItem(PORTFOLIO_KEY, JSON.stringify(holdings)); } catch (e) {}
  renderPortfolio();
  showToast('Position removed');
}

const charts = {}; 
function safeDestroyChart(id) { if (charts[id]) { try { charts[id].destroy(); } catch (e) {} charts[id] = null; } }
function getChartTextColor() { return settings.adaMode ? '#FFFFFF' : '#a8b8c5'; }
function getChartGridColor() { return settings.adaMode ? '#444444' : 'rgba(0, 217, 255, 0.05)'; }

function switchTab(id) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  const navEl = document.querySelector(`.nav-item[data-tab="${id}"]`);
  if (navEl) navEl.classList.add('active');
  renderTab(id);
  setTimeout(() => { Object.keys(charts).forEach(key => { if (charts[key]) { try { charts[key].resize(); } catch(e) {} } }); }, 50);
}

function showToast(msg) { const t = document.getElementById('toast'); t.textContent = msg; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 3000); }

function renderTab(id) {
  if (id === 'overview') renderOverview();
  if (id === 'portfolio') renderPortfolio();
  if (id === 'markets') renderMarkets();
  if (id === 'crypto') renderCrypto();
  if (id === 'options') renderOptions();
  if (id === 'replay') renderReplay();
  if (id === 'agents') renderAgents();
  if (id === 'ai-manager') renderRisk();
}

async function renderOverview() {
  const map = document.getElementById('money-flow-map');
  let svg = `<svg width="100%" height="100%" viewBox="0 0 400 200">`;
  ['Tech', 'Finance', 'Energy', 'Health'].forEach((s, i) => {
    const x = 50 + (i * 100), y = 100;
    svg += `<circle cx="${x}" cy="${y}" r="15" fill="var(--accent)" opacity="0.5"/>`;
    svg += `<text x="${x}" y="${y+35}" fill="var(--text-dim)" font-size="10" text-anchor="middle">${s}</text>`;
    for(let j=0; j<2; j++) svg += `<path d="M ${x} ${y} Q ${Math.random()*400} ${Math.random()*200} ${Math.random()*400} ${Math.random()*200}" stroke="var(--green)" stroke-width="1" fill="none" class="flow-line" opacity="0.5"/>`;
  });
  map.innerHTML = svg + `</svg>`;

  const ctx = document.getElementById('main-chart').getContext('2d');
  const statusDiv = document.getElementById('main-chart-status');
  safeDestroyChart('main');
  charts.main = new Chart(ctx, {
    type: 'line',
    data: { datasets: [{ label: 'SPY', data: [], borderColor: '#00d9ff', backgroundColor: 'rgba(0,217,255,0.1)', fill: true, tension: 0.1 }] },
    options: { 
      responsive: true, maintainAspectRatio: false, 
      scales: { 
        x: { type: 'time', time: { unit: 'day' }, ticks: { color: getChartTextColor() }, grid: { color: getChartGridColor() } },
        y: { ticks: { color: getChartTextColor(), callback: function(value) { return '$' + value.toFixed(0); } }, grid: { color: getChartGridColor() } }
      } 
    }
  });

  statusDiv.textContent = "Fetching live stock data...";
  const spyData = await fetchStockData('SPY');
  if (spyData && !spyData.error) {
    charts.main.data.datasets[0].data = spyData;
    statusDiv.textContent = "Live data via " + settings.stockProvider;
  } else {
    charts.main.data.datasets[0].data = generateMockData(400, 90);
    statusDiv.innerHTML = `<span class="text-[var(--amber)]">${spyData.error || 'Error'} - Showing simulated data.</span>`;
  }
  charts.main.update();
  
  let totalVal = 0, totalInv = 0;
  holdings.forEach(h => { totalInv += h.shares * h.buyPrice; });
  totalVal = totalInv * 1.15; 
  document.getElementById('port-val').textContent = `$${totalVal.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
  document.getElementById('port-pl').textContent = `+$${(totalVal - totalInv).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
  renderTicker();
}

function renderTicker() {
  const track = document.getElementById('ticker-track');
  const symbols = ['AAPL', 'NVDA', 'TSLA', 'MSFT', 'AMZN', 'BTC', 'ETH', 'SPY'];
  const items = symbols.map(s => {
    const price = (Math.random() * 300 + 50).toFixed(2);
    const ch = (Math.random() * 4 - 1).toFixed(2);
    const cls = ch >= 0 ? 'text-[var(--green)]' : 'text-[var(--red)]';
    const arr = ch >= 0 ? 'Up' : 'Down';
    return `<span class="ticker-item"><span class="text-[var(--accent)] font-bold">${s}</span> <span class="text-[var(--text)]">$${price}</span> <span class="${cls}">${arr} ${Math.abs(ch)}%</span></span>`;
  }).join('');
  track.innerHTML = items + items;
}

function renderPortfolio() {
  const tbody = document.getElementById('portfolio-tbody');
  tbody.innerHTML = holdings.map((h, i) => {
    const currentPrice = h.buyPrice * (1 + (Math.random() * 0.3 - 0.1)); 
    const value = h.shares * currentPrice;
    const inv = h.shares * h.buyPrice;
    const pl = value - inv;
    const plClass = pl >= 0 ? 'text-[var(--green)]' : 'text-[var(--red)]';
    return `<tr class="border-b border-[var(--border)]">
      <td class="p-2 text-[var(--accent)] font-bold">${h.ticker}</td>
      <td class="p-2 text-right">${h.shares}</td>
      <td class="p-2 text-right">$${h.buyPrice.toFixed(2)}</td>
      <td class="p-2 text-right">$${currentPrice.toFixed(2)}</td>
      <td class="p-2 text-right ${plClass}">${pl >= 0 ? '+' : ''}$${pl.toFixed(2)}</td>
      <td class="p-2 text-center"><button class="btn btn-red text-[0.6rem] py-1 px-2" onclick="removeHolding(${i})" aria-label="Remove ${h.ticker}">Sell</button></td>
    </tr>`;
  }).join('');
}

