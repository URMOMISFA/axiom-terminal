<script>
const PRIVACY_KEY = 'axiom_privacy_accepted';
if (!localStorage.getItem(PRIVACY_KEY)) document.getElementById('privacy-splash').classList.add('active');
document.getElementById('accept-privacy-btn').addEventListener('click', () => {
  localStorage.setItem(PRIVACY_KEY, 'true');
  document.getElementById('privacy-splash').classList.remove('active');
});

const STORAGE_KEY = 'axiom_settings_v11';
const PORTFOLIO_KEY = 'axiom_portfolio_v11';

function safeParse(key, fallback) {
  try { const data = localStorage.getItem(key); return data ? JSON.parse(data) : fallback; } catch (e) { return fallback; }
}

let settings = safeParse(STORAGE_KEY, { stockProvider: 'twelvedata', stockApiKey: '', aiProvider: 'pollinations', aiKey: '', adaMode: false });
let holdings = safeParse(PORTFOLIO_KEY, [
  { ticker: 'AAPL', shares: 50, buyPrice: 150 }, 
  { ticker: 'BTC', shares: 0.5, buyPrice: 40000 }
]);

if (settings.adaMode) {
  document.body.classList.add('ada-mode');
  document.getElementById('ada-toggle-btn').textContent = 'Disable ADA Compliance Mode';
}

document.getElementById('stock-provider').value = settings.stockProvider || 'twelvedata';
document.getElementById('stock-api-key').value = settings.stockApiKey || '';
document.getElementById('ai-provider').value = settings.aiProvider || 'pollinations';
document.getElementById('ai-key').value = settings.aiKey || '';

updateAIProvider();
if (settings.aiProvider === 'pollinations' || settings.aiKey) document.getElementById('ai-status').textContent = `AI: ${settings.aiProvider.toUpperCase()} ONLINE`;

function toggleAdaMode() {
  settings.adaMode = !settings.adaMode;
  document.body.classList.toggle('ada-mode', settings.adaMode);
  document.getElementById('ada-toggle-btn').textContent = settings.adaMode ? 'Disable ADA Compliance Mode' : 'Enable ADA Compliance Mode';
  saveSettings();
  showToast(settings.adaMode ? 'ADA Mode Enabled' : 'ADA Mode Disabled');
  const activeTab = document.querySelector('.nav-item.active');
  if (activeTab) renderTab(activeTab.dataset.tab);
}

function saveSettings() {
  settings.stockProvider = document.getElementById('stock-provider').value;
  settings.stockApiKey = document.getElementById('stock-api-key').value;
  settings.aiProvider = document.getElementById('ai-provider').value;
  settings.aiKey = document.getElementById('ai-key').value;
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(settings)); } catch (e) {}
  if (settings.aiProvider === 'pollinations' || settings.aiKey) document.getElementById('ai-status').textContent = `AI: ${settings.aiProvider.toUpperCase()} ONLINE`;
  else document.getElementById('ai-status').textContent = 'AI OFFLINE';
  showToast('Settings Saved');
}

function updateAIProvider() {
  const provider = document.getElementById('ai-provider').value;
  const keyContainer = document.getElementById('ai-key-container');
  const keyInput = document.getElementById('ai-key');
  const helpLinks = document.getElementById('ai-help-links');
  helpLinks.innerHTML = '';
  if (provider === 'pollinations') {
    keyContainer.style.display = 'none';
    keyInput.value = '';
  } else {
    keyContainer.style.display = 'block';
    if (provider === 'openrouter') {
      keyInput.placeholder = 'sk-or-v1-...';
      helpLinks.innerHTML = '<a href="https://openrouter.ai/keys" target="_blank" class="text-[var(--accent)] underline">Get Free OpenRouter API Key</a>';
    } else if (provider === 'gemini') {
      keyInput.placeholder = 'AIza...';
      helpLinks.innerHTML = '<a href="https://aistudio.google.com/app/apikey" target="_blank" class="text-[var(--accent)] underline">Get Free Google Gemini API Key</a>';
    } else if (provider === 'openai') {
      keyInput.placeholder = 'sk-...';
      helpLinks.innerHTML = '<a href="https://platform.openai.com/api-keys" target="_blank" class="text-[var(--accent)] underline">Get OpenAI API Key (Paid)</a>';
    } else if (provider === 'claude') {
      keyInput.placeholder = 'sk-ant-...';
      helpLinks.innerHTML = '<a href="https://console.anthropic.com/" target="_blank" class="text-[var(--accent)] underline">Get Anthropic API Key (Paid)</a>';
    }
  }
}

async function fetchCryptoData(symbol = 'BTCUSDT', interval = '1d', limit = 120) {
  try {
    const res = await fetch(`https://api.binance.com/api/v3/klines?symbol=${symbol}&interval=${interval}&limit=${limit}`);
    if (!res.ok) throw new Error('Binance Network Error');
    const data = await res.json();
    return data.map(d => ({ x: new Date(d[0]), y: parseFloat(d[4]) })); 
  } catch (e) { return null; }
}

async function fetchStockData(ticker, isReplay = false) {
  const provider = settings.stockProvider || 'twelvedata';
  const key = settings.stockApiKey;
  if (!key) return { error: "No Stock API key. Please enter a free key in Settings." };
  try {
    if (provider === 'twelvedata') {
      let url;
      if (isReplay) url = `https://api.twelvedata.com/time_series?symbol=SPY&interval=1day&start_date=2020-02-01&end_date=2020-04-30&apikey=${key}`;
      else url = `https://api.twelvedata.com/time_series?symbol=${ticker}&interval=1day&outputsize=90&apikey=${key}`;
      const res = await fetch(url);
      const data = await res.json();
      if (data.status === 'error') throw new Error(data.message);
      return data.values.reverse().map(v => ({ x: new Date(v.datetime), y: parseFloat(v.close) }));
    } else if (provider === 'finnhub') {
      const to = Math.floor(Date.now() / 1000);
      const from = to - 7776000; 
      const res = await fetch(`https://finnhub.io/api/v1/stock/candle?symbol=${ticker}&resolution=D&from=${from}&to=${to}&token=${key}`);
      const data = await res.json();
      if (data.s !== 'ok') throw new Error('Finnhub error or invalid key');
      return data.t.map((t, i) => ({ x: new Date(t * 1000), y: data.c[i] }));
    } else if (provider === 'alphavantage') {
      const res = await fetch(`https://www.alphavantage.co/query?function=TIME_SERIES_DAILY&symbol=${ticker}&outputsize=compact&apikey=${key}`);
      const data = await res.json();
      if (data.Note) throw new Error('Alpha Vantage rate limit reached.');
      const timeseries = data['Time Series (Daily)'];
      if (!timeseries) throw new Error(data['Error Message'] || 'Alpha Vantage error');
      return Object.entries(timeseries).map(([date, val]) => ({ x: new Date(date), y: parseFloat(val['4. close']) })).reverse().slice(0, 90);
    }
  } catch (e) { return { error: e.message }; }
}

function generateMockData(basePrice, days, trend = 0) {
  let data = [], price = basePrice;
  for (let i = 0; i < days; i++) {
    price = price * (1 + (Math.random() - 0.48 + trend * 0.01) * 0.03);
    data.push({ x: new Date(Date.now() - (days - i) * 86400000), y: price });
  }
  return data;
}

async function queryAI(userPrompt, systemPrompt = "You are AXIOM, a trading intelligence assistant. Be concise.") {
  const provider = settings.aiProvider || 'pollinations';
  try {
    if (provider === 'pollinations') {
      try {
        const res = await fetch('https://text.pollinations.ai/openai', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ model: 'openai', messages: [{role: 'system', content: systemPrompt}, {role: 'user', content: userPrompt}], temperature: 0.4 })
        });
        if (res.ok) {
          const text = await res.text();
          try { const data = JSON.parse(text); return data.choices[0].message.content; } catch { return text; }
        }
      } catch (e) {}
      try {
        const combinedPrompt = `${systemPrompt}\n\nUser Query: ${userPrompt}`;
        const res = await fetch(`https://text.pollinations.ai/${encodeURIComponent(combinedPrompt)}`);
        if (res.ok) return await res.text();
      } catch (e) {}
      return "Error: Pollinations AI is currently unavailable or rate-limited. Please try OpenRouter (free) in settings.";
    }

    const key = settings.aiKey.trim();
    if (!key || key.length < 10) return `Error: ${provider.toUpperCase()} API key is missing or invalid. Please go to Settings and enter a valid API key.`;

    let response, data;
    if (provider === 'openrouter') {
      const models = ['meta-llama/llama-3.1-8b-instruct:free', 'google/gemma-2-9b-it:free', 'mistralai/mistral-7b-instruct:free'];
      let lastError = null;
      for (const model of models) {
        try {
          response = await fetch('https://openrouter.ai/api/v1/chat/completions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${key}`, 'HTTP-Referer': 'https://axiom-terminal.app', 'X-Title': 'AXIOM Terminal' },
            body: JSON.stringify({ model: model, messages: [{role: 'system', content: systemPrompt}, {role: 'user', content: userPrompt}], temperature: 0.4 })
          });
          data = await response.json();
          if (data.error) { lastError = typeof data.error === 'string' ? data.error : data.error.message; continue; }
          return data.choices[0].message.content;
        } catch (e) { lastError = e.message; continue; }
      }
      throw new Error(lastError || 'OpenRouter request failed');
    } else if (provider === 'gemini') {
       response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${key}`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ contents: [{ parts: [{ text: systemPrompt + "\n\n" + userPrompt }] }] })
      });
      data = await response.json();
      if(data.error) throw new Error(typeof data.error === 'string' ? data.error : data.error.message);
      return data.candidates[0].content.parts[0].text;
    } else if (provider === 'openai') {
      response = await fetch('https://api.openai.com/v1/chat/completions', {
        method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${key}` },
        body: JSON.stringify({ model: 'gpt-4o-mini', messages: [{role: 'system', content: systemPrompt}, {role: 'user', content: userPrompt}], temperature: 0.4 })
      });
      data = await response.json();
      if(data.error) throw new Error(typeof data.error === 'string' ? data.error : data.error.message);
      return data.choices[0].message.content;
    } else if (provider === 'claude') {
      response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'x-api-key': key, 'anthropic-version': '2023-06-01', 'anthropic-dangerous-direct-browser-access': 'true', 'Content-Type': 'application/json' },
        body: JSON.stringify({ model: 'claude-3-haiku-20240307', max_tokens: 1024, system: systemPrompt, messages: [{role: 'user', content: userPrompt}] })
      });
      data = await response.json();
      if(data.error) throw new Error(typeof data.error === 'string' ? data.error : data.error.message);
      return data.content[0].text;
    }
  } catch (e) { return "AI Error: " + e.message; }
}

const commands = [
  { label: 'Go to Overview', action: () => switchTab('overview') },
  { label: 'Go to Crypto', action: () => switchTab('crypto') },
  { label: 'Go to Portfolio', action: () => switchTab('portfolio') },
  { label: 'Go to Settings', action: () => switchTab('settings') },
  { label: 'Go to AI Agents', action: () => switchTab('agents') },
  { label: 'Open AI Chat', action: () => document.getElementById('chat-modal').classList.remove('hidden') },
];
function openCmdPalette() { 
  document.getElementById('cmd-palette').classList.add('active'); 
  document.getElementById('cmd-input').value = ''; 
  filterCmd(); 
  setTimeout(() => document.getElementById('cmd-input').focus(), 50);
}
function filterCmd() {
  const q = document.getElementById('cmd-input').value.toLowerCase();
  const resultsDiv = document.getElementById('cmd-results');
  resultsDiv.innerHTML = '';
  commands.filter(c => c.label.toLowerCase().includes(q)).forEach(c => {
    const el = document.createElement('div');
    el.className = 'cmd-result'; el.setAttribute('role', 'option'); el.tabIndex = 0; el.textContent = c.label;
    el.onclick = () => { c.action(); document.getElementById('cmd-palette').classList.remove('active'); };
    el.onkeydown = (e) => { if(e.key==='Enter'||e.key===' ') { e.preventDefault(); c.action(); document.getElementById('cmd-palette').classList.remove('active'); }};
    resultsDiv.appendChild(el);
  });
}

function startVoice() {
  const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRec) { showToast('Voice API not supported'); return; }
  try {
    const recognition = new SpeechRec();
    recognition.lang = 'en-US';
    recognition.onresult = (e) => {
      const text = e.results[0][0].transcript;
      showToast('Heard: ' + text);
      if (text.toLowerCase().includes('agent')) switchTab('agents');
      if (text.toLowerCase().includes('market')) switchTab('markets');
    };
    recognition.start();
    showToast('Listening...');
  } catch (e) { showToast('Microphone access denied.'); }
}

