function renderAgents() {
  const list = document.getElementById('agent-list');
  if (!list) return;
  list.innerHTML = '';
  agents.forEach(a => {
    const el = document.createElement('div');
    el.className = `p-3 rounded cursor-pointer border ${activeAgent.id === a.id ? 'border-[var(--accent)] bg-[rgba(0,217,255,0.1)]' : 'border-[var(--border)]'}`;
    el.innerHTML = `<div class="font-bold" style="color:${a.color}">${a.name}</div>`;
    el.tabIndex = 0; el.setAttribute('role', 'button');
