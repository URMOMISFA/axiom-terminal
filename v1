<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AXIOM Terminal v11.8</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #05080d; --bg-2: #0a131c; --panel: rgba(10, 22, 35, 0.75); --border: rgba(0, 217, 255, 0.15); --border-bright: rgba(0, 217, 255, 0.5);
  --accent: #00d9ff; --amber: #ffb800; --green: #00ff9d; --red: #ff3b5c; --pink: #ff6b9d; --purple: #a855f7;
  --text: #e8f0f5; --text-dim: #a8b8c5; --muted: #5a7080;
}
* { box-sizing: border-box; } html, body { margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: 'Rajdhani', sans-serif; min-height: 100vh; overflow-x: hidden; }
.bg-grid { position: fixed; inset: 0; background-image: linear-gradient(rgba(0,217,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0,217,255,0.04) 1px, transparent 1px); background-size: 60px 60px; pointer-events: none; z-index: 0; mask-image: radial-gradient(ellipse at center, black 0%, transparent 80%); }
.bg-glow { position: fixed; inset: 0; background: radial-gradient(ellipse 900px 700px at 15% 20%, rgba(0,217,255,0.08), transparent), radial-gradient(ellipse 700px 500px at 85% 80%, rgba(255,184,0,0.05), transparent); pointer-events: none; z-index: 0; }
.font-display { font-family: 'Orbitron', sans-serif; letter-spacing: 0.05em; } .font-mono { font-family: 'JetBrains Mono', monospace; }
.panel { background: var(--panel); border: 1px solid var(--border); border-radius: 4px; backdrop-filter: blur(10px); position: relative; }
.panel::before { content: ''; position: absolute; top: -1px; left: -1px; right: -1px; height: 1px; background: linear-gradient(90deg, transparent, var(--accent), transparent); opacity: 0.6; }
.panel-glow:hover { border-color: var(--border-bright); box-shadow: 0 0 30px rgba(0,217,255,0.1); }
.bracket::before, .bracket::after { content: ''; position: absolute; width: 12px; height: 12px; border: 1px solid var(--accent); pointer-events: none; }
.bracket::before { top: -1px; left: -1px; border-right: none; border-bottom: none; } .bracket::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }
.btn { font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; font-size: 0.72rem; padding: 8px 16px; background: rgba(0,217,255,0.08); border: 1px solid var(--border-bright); color: var(--accent); cursor: pointer; transition: all 0.2s; border-radius: 2px; }
.btn:hover { background: rgba(0,217,255,0.18); } .btn-amber { background: rgba(255,184,0,0.08); border-color: rgba(255,184,0,0.5); color: var(--amber); }
.btn-red { background: rgba(255,59,92,0.08); border-color: rgba(255,59,92,0.5); color: var(--red); }
.btn-ghost { background: transparent; border-color: var(--border); color: var(--text-dim); }
.input { background: rgba(0,0,0,0.4); border: 1px solid var(--border); color: var(--text); padding: 10px 14px; font-family: 'JetBrains Mono'; font-size: 0.9rem; width: 100%; outline: none; border-radius: 2px; }
.input:focus { border-color: var(--accent); } textarea.input { font-family: 'Rajdhani'; resize: vertical; }
.badge { display: inline-flex; padding: 3px 8px; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; border: 1px solid; border-radius: 2px; }
.badge-buy { color: var(--green); border-color: rgba(0,255,157,0.4); background: rgba(0,255,157,0.08); } .badge-sell { color: var(--red); border-color: rgba(255,59,92,0.4); background: rgba(255,59,92,0.08); }
::-webkit-scrollbar { width: 6px; height: 6px; } ::-webkit-scrollbar-track { background: var(--bg-2); } ::-webkit-scrollbar-thumb { background: var(--border-bright); }
.section-title { font-family: 'Orbitron'; font-weight: 700; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
.section-title::before { content: ''; width: 4px; height: 14px; background: var(--accent); box-shadow: 0 0 8px var(--accent); } .section-title::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg, var(--border-bright), transparent); }
.nav-item { display: flex; align-items: center; gap: 14px; padding: 10px 18px; border-left: 2px solid transparent; cursor: pointer; color: var(--text-dim); font-weight: 500; text-transform: uppercase; font-size: 0.75rem; }
.nav-item:hover { background: rgba(0,217,255,0.05); color: var(--accent); } .nav-item.active { background: linear-gradient(90deg, rgba(0,217,255,0.15), transparent); border-left-color: var(--accent); color: var(--accent); }
.nav-item:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }
.tab-content { display: none; } .tab-content.active { display: block; }
.cmd-palette { position: fixed; top: 20%; left: 50%; transform: translateX(-50%); width: 600px; max-width: 90vw; background: var(--bg-2); border: 1px solid var(--border-bright); border-radius: 6px; z-index: 300; box-shadow: 0 0 60px rgba(0,217,255,0.4); display: none; flex-direction: column; }
.cmd-palette.active { display: flex; } .cmd-input { width: 100%; padding: 16px; background: transparent; border: none; border-bottom: 1px solid var(--border); color: var(--accent); font-family: 'JetBrains Mono'; outline: none; }
.cmd-result { padding: 12px 16px; cursor: pointer; border-bottom: 1px solid var(--border); } .cmd-result:hover, .cmd-result:focus-visible { background: rgba(0,217,255,0.1); outline: none; }
.toast { position: fixed; bottom: 80px; right: 30px; background: var(--bg-2); border: 1px solid var(--border-bright); border-left: 3px solid var(--accent); padding: 14px 22px; z-index: 200; transform: translateX(120%); transition: transform 0.4s; border-radius: 2px; }
.toast.show { transform: translateX(0); }
.chat-msg { max-width: 85%; padding: 10px 14px; border-radius: 6px; font-size: 0.85rem; margin-bottom: 8px; } .chat-msg.user { align-self: flex-end; background: rgba(0,217,255,0.12); border: 1px solid var(--border-bright); color: var(--accent); } .chat-msg.ai { align-self: flex-start; background: rgba(255,255,255,0.04); border: 1px solid var(--border); color: var(--text); }
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 100; display: none; align-items: center; justify-content: center; } .modal-overlay.active { display: flex; }
.modal { background: var(--bg-2); border: 1px solid var(--border-bright); border-radius: 4px; max-width: 900px; width: 100%; max-height: 85vh; overflow-y: auto; }
.spin { animation: spin 1s linear infinite; } @keyframes spin { to { transform: rotate(360deg); } }
.flow-line { stroke-dasharray: 4 4; animation: dash 1s linear infinite; } @keyframes dash { to { stroke-dashoffset: -8; } }
.globe-rotate { animation: rotate 30s linear infinite; transform-origin: center; } @keyframes rotate { to { transform: rotate(360deg); } }
.ticker-tape { background: var(--bg-2); border-top: 1px solid var(--border); overflow: hidden; white-space: nowrap; padding: 8px 0; position: relative; }
.ticker-track { display: inline-block; animation: scroll 80s linear infinite; }
@keyframes scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.ticker-item { display: inline-block; padding: 0 24px; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; }

body.ada-mode {
  --bg: #000000; --bg-2: #0a0a0a; --panel: #111111; --border: #FFFFFF; --border-bright: #FFFF00;
  --accent: #00FFFF; --amber: #FFA500; --green: #00FF00; --red: #FF0000; --pink: #FF00FF; --purple: #8A2BE2;
  --text: #FFFFFF; --text-dim: #CCCCCC; --muted: #AAAAAA;
}
body.ada-mode .bg-grid, body.ada-mode .bg-glow { display: none; }
body.ada-mode .panel { backdrop-filter: none; border-width: 2px; }
body.ada-mode .panel::before { display: none; }
body.ada-mode .bracket::before, body.ada-mode .bracket::after { border-width: 2px; }
body.ada-mode .btn, body.ada-mode .input, body.ada-mode .nav-item { border-width: 2px; }
body.ada-mode .nav-item.active { background: #00FFFF; color: #000000; }
body.ada-mode * { text-shadow: none !important; box-shadow: none !important; }
body.ada-mode .globe-rotate, body.ada-mode .flow-line, body.ada-mode .spin, body.ada-mode .ticker-track { animation: none !important; }
body.ada-mode *:focus-visible { outline: 3px solid #FFFF00 !important; outline-offset: 2px !important; }
</style>
</head>
<body>
<div class="bg-grid"></div><div class="bg-glow"></div>

<div id="privacy-splash" class="modal-overlay" style="z-index: 9999;">
  <div class="modal p-8 max-w-2xl">
    <div class="font-display text-2xl text-[var(--accent)] mb-4">AXIOM Terminal Privacy Policy</div>
    <div class="text-sm text-[var(--text-dim)] space-y-4 mb-6">
      <p>Welcome to AXIOM Terminal. Before you begin, please review our privacy and data usage terms:</p>
      <p><strong class="text-[var(--text)]">1. Local Data Storage:</strong> Your portfolio holdings, API keys, and settings are stored entirely in your browser's Local Storage. They never touch our servers.</p>
      <p><strong class="text-[var(--text)]">2. Third-Party APIs:</strong> To fetch live stock and crypto data, your browser connects directly to providers like Binance, Twelve Data, and Finnhub. Your search queries are sent directly to them.</p>
      <p><strong class="text-[var(--text)]">3. AI Providers:</strong> If you configure an AI provider (OpenRouter, Gemini, OpenAI, etc.), your chat messages and portfolio context are sent directly to that provider for processing.</p>
      <p><strong class="text-[var(--text)]">4. No Tracking:</strong> We do not use cookies, analytics, or tracking pixels.</p>
    </div>
    <button id="accept-privacy-btn" class="btn w-full text-base py-3">Accept & Continue</button>
  </div>
</div>

<header class="relative z-10 border-b border-[var(--border)] bg-[rgba(5,8,13,0.85)] backdrop-blur">
  <div class="flex items-center justify-between px-6 py-2">
    <div class="flex items-center gap-4">
      <div class="font-display font-black text-lg tracking-widest text-[var(--accent)]">AXIOM</div>
      <div class="font-mono text-[0.55rem] text-[var(--muted)] tracking-[0.2em]">TERMINAL v11.8</div>
    </div>
    <div class="hidden md:flex items-center gap-5">
      <button class="btn btn-ghost text-xs py-1" onclick="openCmdPalette()" aria-label="Open Command Palette">Cmd+K Search</button>
      <button class="btn btn-ghost text-xs py-1" id="voice-btn" onclick="startVoice()" aria-label="Start Voice Command">Voice</button>
      <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-[var(--green)] animate-pulse"></div><span class="font-mono text-xs text-[var(--text-dim)]" id="ai-status">AI OFFLINE</span></div>
      <div class="font-mono text-sm text-[var(--accent)]" id="clock">--:--:--</div>
    </div>
  </div>
</header>

<div class="relative z-10 flex" style="min-height: calc(100vh - 100px);">
  <aside class="w-52 border-r border-[var(--border)] bg-[rgba(5,8,13,0.6)] flex-shrink-0 overflow-y-auto" style="max-height: calc(100vh - 100px);">
    <nav class="py-4" aria-label="Main Navigation">
      <div class="px-4 py-2 text-[0.55rem] text-[var(--muted)] tracking-[0.2em] uppercase">Core</div>
      <div class="nav-item active" data-tab="overview" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('overview')}" onclick="switchTab('overview')">Overview</div>
      <div class="nav-item" data-tab="portfolio" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('portfolio')}" onclick="switchTab('portfolio')">Portfolio</div>
      <div class="nav-item" data-tab="markets" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('markets')}" onclick="switchTab('markets')">Markets</div>
      <div class="nav-item" data-tab="crypto" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('crypto')}" onclick="switchTab('crypto')">Crypto</div>
      <div class="nav-item" data-tab="scanners" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('scanners')}" onclick="switchTab('scanners')">Scanners</div>
      
      <div class="px-4 py-2 text-[0.55rem] text-[var(--muted)] tracking-[0.2em] uppercase">Intelligence</div>
      <div class="nav-item" data-tab="ai-manager" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('ai-manager')}" onclick="switchTab('ai-manager')">AI Manager</div>
      <div class="nav-item" data-tab="agents" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('agents')}" onclick="switchTab('agents')">AI Agents</div>
      <div class="nav-item" data-tab="debate" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('debate')}" onclick="switchTab('debate')">AI Debate</div>
      
      <div class="px-4 py-2 text-[0.55rem] text-[var(--muted)] tracking-[0.2em] uppercase">Institutional</div>
      <div class="nav-item" data-tab="options" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('options')}" onclick="switchTab('options')">Options/Dark Pool</div>
      <div class="nav-item" data-tab="research" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('research')}" onclick="switchTab('research')">Research</div>
      
      <div class="px-4 py-2 text-[0.55rem] text-[var(--muted)] tracking-[0.2em] uppercase">Tools & Fun</div>
      <div class="nav-item" data-tab="automation" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('automation')}" onclick="switchTab('automation')">Automation</div>
      <div class="nav-item" data-tab="goals" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('goals')}" onclick="switchTab('goals')">Goals & Gamification</div>
      <div class="nav-item" data-tab="replay" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('replay')}" onclick="switchTab('replay')">Market Replay</div>
      <div class="nav-item" data-tab="globe" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('globe')}" onclick="switchTab('globe')">Global Globe</div>
      <div class="nav-item" data-tab="settings" tabindex="0" role="button" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('settings')}" onclick="switchTab('settings')">Settings</div>
    </nav>
  </aside>

  <main class="flex-1 p-6 overflow-x-hidden">
    <section id="tab-overview" class="tab-content active">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-6">
        <div class="lg:col-span-2 panel bracket p-5">
          <div class="section-title">AI Market Narrator & Regime Engine</div>
          <div class="text-base text-[var(--text-dim)] mb-4" id="briefing-text">Market regime is currently TRENDING. Technology is leading today's rally while healthcare lags. Volatility is contracting.</div>
          <div class="grid grid-cols-4 gap-3">
            <div class="bg-black/20 p-2 text-center"><div class="text-[0.6rem] text-[var(--muted)]">REGIME</div><div class="font-mono text-[var(--accent)]">TRENDING</div></div>
            <div class="bg-black/20 p-2 text-center"><div class="text-[0.6rem] text-[var(--muted)]">VIX</div><div class="font-mono text-[var(--amber)]">17.42</div></div>
            <div class="bg-black/20 p-2 text-center"><div class="text-[0.6rem] text-[var(--muted)]">BREADTH</div><div class="font-mono text-[var(--green)]">62% UP</div></div>
            <div class="bg-black/20 p-2 text-center"><div class="text-[0.6rem] text-[var(--muted)]">FEAR/GREED</div><div class="font-mono text-[var(--green)]">68 GREED</div></div>
          </div>
        </div>
        <div class="panel bracket p-5 flex flex-col items-center justify-center">
          <div class="section-title w-full">Money Flow Map</div>
          <div id="money-flow-map" class="relative bg-black/20 rounded" style="height:200px;" aria-label="Animated map showing money flow between sectors"></div>
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="panel p-4"><div class="text-[0.6rem] text-[var(--muted)]">PORTFOLIO VALUE</div><div class="font-mono text-xl font-bold text-[var(--accent)]" id="port-val">$0</div></div>
        <div class="panel p-4"><div class="text-[0.6rem] text-[var(--muted)]">TOTAL P/L</div><div class="font-mono text-xl font-bold text-[var(--green)]" id="port-pl">$0</div></div>
        <div class="panel p-4"><div class="text-[0.6rem] text-[var(--muted)]">PREDICTED RISK</div><div class="font-mono text-xl font-bold text-[var(--amber)]">42/100</div></div>
        <div class="panel p-4"><div class="text-[0.6rem] text-[var(--muted)]">DARK POOL VOL</div><div class="font-mono text-xl font-bold text-[var(--purple)]">$1.2B</div></div>
      </div>
      <div class="panel bracket p-5">
        <div class="section-title">S&P 500 (SPY)</div>
        <div style="height:300px;"><canvas id="main-chart" role="img" aria-label="Line chart of S&P 500 prices"></canvas></div>
        <div id="main-chart-status" class="text-center text-[var(--muted)] text-xs mt-2"></div>
      </div>
    </section>

    <section id="tab-portfolio" class="tab-content">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        <div class="lg:col-span-2 panel bracket p-5">
          <div class="section-title">Active Positions</div>
          <table class="w-full font-mono text-sm">
            <thead><tr class="text-[0.65rem] text-[var(--muted)] uppercase border-b border-[var(--border)]"><th class="text-left p-2">Ticker</th><th class="text-right p-2">Shares</th><th class="text-right p-2">Buy Price</th><th class="text-right p-2">Current</th><th class="text-right p-2">P/L</th><th class="text-center p-2">Actions</th></tr></thead>
            <tbody id="portfolio-tbody"></tbody>
          </table>
        </div>
        <div class="panel bracket p-5">
          <div class="section-title">Add Position (Any Ticker)</div>
          <form onsubmit="addHolding(event)" class="space-y-3">
            <input type="text" class="input" id="new-ticker" placeholder="Ticker (e.g. AAPL or BTC)" required aria-label="Ticker Symbol">
            <input type="number" step="any" class="input" id="new-shares" placeholder="Shares / Coins" required aria-label="Number of Shares">
            <input type="number" step="any" class="input" id="new-price" placeholder="Buy Price ($)" required aria-label="Buy Price">
            <button type="submit" class="btn w-full">+ Add to Portfolio</button>
          </form>
          <div class="mt-6">
            <div class="section-title">Digital Twin (What-If)</div>
            <p class="text-xs text-[var(--text-dim)] mb-4">Simulate adding $10,000 to a stock.</p>
            <button class="btn w-full" onclick="runTwin()">Run Simulation</button>
            <div id="twin-results" class="mt-4 text-sm font-mono"></div>
          </div>
        </div>
      </div>
    </section>

    <section id="tab-markets" class="tab-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
        <div class="panel bracket p-5"><div class="section-title">Sector Heatmap</div><div class="grid grid-cols-3 md:grid-cols-4 gap-2" id="heatmap"></div></div>
        <div class="panel bracket p-5"><div class="section-title">Relative Strength Rankings</div><div id="strength-rankings" class="space-y-2"></div></div>
      </div>
    </section>

    <section id="tab-crypto" class="tab-content">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        <div class="panel bracket p-5 lg:col-span-2">
          <div class="section-title">Live Crypto Chart (Binance API)</div>
          <div class="flex gap-3 mb-4">
            <input type="text" class="input" id="crypto-input" value="BTCUSDT" placeholder="e.g. ETHUSDT" aria-label="Crypto Trading Pair">
            <button class="btn" onclick="loadCryptoChart()">Load Chart</button>
          </div>
          <div style="height:400px;"><canvas id="crypto-chart" role="img" aria-label="Line chart of cryptocurrency prices"></canvas></div>
          <div id="crypto-chart-status" class="text-center text-[var(--muted)] text-xs mt-2"></div>
        </div>
        <div class="panel bracket p-5">
          <div class="section-title">Top Crypto Markets</div>
          <div id="crypto-list" class="space-y-2 overflow-y-auto" style="max-height: 400px;"></div>
        </div>
      </div>
    </section>

    <section id="tab-scanners" class="tab-content">
      <div class="panel bracket p-5 mb-6">
        <div class="section-title">Natural Language Strategy Builder</div>
        <textarea class="input mb-3" id="nl-strategy-input" placeholder="e.g., Find stocks where RSI is below 30 and volume is 2x average" aria-label="Strategy description"></textarea>
        <button class="btn" onclick="buildNLStrategy()">Generate & Scan</button>
        <div id="nl-results" class="mt-4 text-sm font-mono"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="panel p-4"><div class="text-[0.6rem] text-[var(--muted)]">MOMENTUM</div><div class="text-2xl font-bold text-[var(--green)]">5 Stocks</div><div class="text-xs text-[var(--accent)] mt-2 cursor-pointer hover:underline">View List</div></div>
        <div class="panel p-4"><div class="text-[0.6rem] text-[var(--muted)]">BREAKOUTS</div><div class="text-2xl font-bold text-[var(--accent)]">3 Stocks</div><div class="text-xs text-[var(--accent)] mt-2 cursor-pointer hover:underline">View List</div></div>
        <div class="panel p-4"><div class="text-[0.6rem] text-[var(--muted)]">OVERSOLD</div><div class="text-2xl font-bold text-[var(--amber)]">8 Stocks</div><div class="text-xs text-[var(--accent)] mt-2 cursor-pointer hover:underline">View List</div></div>
        <div class="panel p-4"><div class="text-[0.6rem] text-[var(--muted)]">SHORT SQUEEZE</div><div class="text-2xl font-bold text-[var(--red)]">2 Stocks</div><div class="text-xs text-[var(--accent)] mt-2 cursor-pointer hover:underline">View List</div></div>
      </div>
    </section>

